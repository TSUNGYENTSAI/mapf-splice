    {"id": "P3", "kind": "handoff", "cell": {"row": 14, "col": 10}},
    {"id": "D1", "kind": "delivery", "cell": {"row": 2, "col": 10}},
    {"id": "D2", "kind": "delivery", "cell": {"row": 7, "col": 2}},
