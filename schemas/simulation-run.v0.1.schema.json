{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "simulation-run.v0.1.schema.json",
  "title": "MAPF Splice deterministic simulation replay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "scenario_id", "committed_horizon", "stable_scc_observation_threshold", "simulation_config", "scenario_content_hash", "map_content_hash", "source_git_commit", "termination_reason", "final_tick", "checkpoint_names", "map_rows", "stations", "frames"],
  "properties": {
    "$schema": {"const": "simulation-run.v0.1.schema.json"},
    "schema_version": {"const": "simulation-run.v0.1"},
    "scenario_id": {"type": "string", "minLength": 1},
    "committed_horizon": {"type": "integer", "minimum": 1},
    "stable_scc_observation_threshold": {"type": "integer", "minimum": 1},
    "simulation_config": {"type": "object"},
    "scenario_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "map_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_git_commit": {"type": ["string", "null"]},
    "termination_reason": {"enum": ["quiescence", "tick"]},
    "final_tick": {"type": "integer", "minimum": 0},
    "checkpoint_names": {"type": "array", "items": {"type": "string"}, "minItems": 7, "uniqueItems": true},
    "map_rows": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "stations": {"type": "array", "items": {"$ref": "#/$defs/station"}},
    "frames": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/frame"}}
  },
  "$defs": {
    "cell": {"type": "object", "additionalProperties": false, "required": ["row", "col"], "properties": {"row": {"type": "integer", "minimum": 0}, "col": {"type": "integer", "minimum": 0}}},
    "station": {"type": "object", "additionalProperties": false, "required": ["station_id", "kind", "cell"], "properties": {"station_id": {"type": "string"}, "kind": {"enum": ["handoff", "delivery"]}, "cell": {"$ref": "#/$defs/cell"}}},
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "tick", "checkpoint", "robots", "tasks", "plans", "reservations", "preview", "deadlock", "events"],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "tick": {"type": "integer", "minimum": 0},
        "checkpoint": {"type": "string"},
        "robots": {"type": "array", "items": {"type": "object"}},
        "tasks": {"type": "array", "items": {"type": "object"}},
        "plans": {"type": "array", "items": {"type": "object"}},
        "reservations": {"type": "array", "items": {"type": "object"}},
        "preview": {"type": "object", "required": ["dependencies", "contentions", "cyclic_sccs"]},
        "deadlock": {"type": "object", "required": ["threshold", "candidates", "containments", "newly_stable"]},
        "events": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
