{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "simulation-run.v0.2.schema.json",
  "title": "MAPF Splice deterministic simulation replay v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "scenario_id", "committed_horizon", "stable_scc_observation_threshold", "simulation_config", "scenario_content_hash", "map_content_hash", "source_git_commit", "termination_reason", "final_tick", "checkpoint_names", "map_rows", "stations", "frames"],
  "properties": {
    "$schema": {"const": "simulation-run.v0.2.schema.json"},
    "schema_version": {"const": "simulation-run.v0.2"},
    "scenario_id": {"type": "string", "minLength": 1},
    "committed_horizon": {"type": "integer", "minimum": 1},
    "stable_scc_observation_threshold": {"type": "integer", "minimum": 1},
    "simulation_config": {"type": "object"},
    "scenario_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "map_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_git_commit": {"type": ["string", "null"]},
    "termination_reason": {"enum": ["quiescence", "tick"]},
    "final_tick": {"type": "integer", "minimum": 0},
    "checkpoint_names": {"type": "array", "items": {"type": "string"}, "minItems": 8, "uniqueItems": true},
    "map_rows": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "stations": {"type": "array", "items": {"$ref": "#/$defs/station"}},
    "frames": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/frame"}}
  },
  "$defs": {
    "cell": {"type": "object", "additionalProperties": false, "required": ["row", "col"], "properties": {"row": {"type": "integer", "minimum": 0}, "col": {"type": "integer", "minimum": 0}}},
    "station": {"type": "object", "additionalProperties": false, "required": ["station_id", "kind", "cell"], "properties": {"station_id": {"type": "string"}, "kind": {"enum": ["handoff", "delivery"]}, "cell": {"$ref": "#/$defs/cell"}}},
    "action_ref": {"type": "object", "additionalProperties": false, "required": ["robot_id", "plan_version", "action_index", "label"], "properties": {"robot_id": {"type": "string"}, "plan_version": {"type": "integer", "minimum": 1}, "action_index": {"type": "integer", "minimum": 0}, "label": {"type": "string"}}},
    "deadlock_candidate": {"type": "object", "additionalProperties": false, "required": ["trigger_core", "scope", "observation_count", "stable"], "properties": {"trigger_core": {"type": "array"}, "scope": {"type": "array"}, "observation_count": {"type": "integer", "minimum": 0}, "stable": {"type": "boolean"}}},
    "containment": {"type": "object", "additionalProperties": false, "required": ["trigger_core", "scope", "state", "confirmation_tick", "outcome"], "properties": {"trigger_core": {"type": "array"}, "scope": {"type": "array"}, "state": {"enum": ["draining", "quiescent", "confirmed-deadlock", "unsupported"]}, "confirmation_tick": {"type": ["integer", "null"], "minimum": 0}, "outcome": {"enum": ["confirmed-deadlock", "unsupported-external", "clear", null]}}},
    "confirmed_edge": {"type": "object", "additionalProperties": false, "required": ["waiting_robot_id", "waiting_plan_version", "waiting_action_ref", "resource", "blocking_robot_id", "blocking_plan_version", "committed_blocker_refs", "occupied_blocker", "blocking_in_scope"], "properties": {"waiting_robot_id": {"type": "string"}, "waiting_plan_version": {"type": "integer", "minimum": 1}, "waiting_action_ref": {"$ref": "#/$defs/action_ref"}, "resource": {"type": "object"}, "blocking_robot_id": {"type": "string"}, "blocking_plan_version": {"type": "integer", "minimum": 0}, "committed_blocker_refs": {"type": "array", "items": {"$ref": "#/$defs/action_ref"}}, "occupied_blocker": {"type": "boolean"}, "blocking_in_scope": {"type": "boolean"}}},
    "confirmed_graph": {"type": "object", "additionalProperties": false, "required": ["scope", "captured_at_tick", "outcome", "state", "edges", "cyclic_sccs"], "properties": {"scope": {"type": "array"}, "captured_at_tick": {"type": "integer", "minimum": 0}, "outcome": {"enum": ["confirmed-deadlock", "unsupported-external", "clear"]}, "state": {"enum": ["draining", "quiescent", "confirmed-deadlock", "unsupported"]}, "edges": {"type": "array", "items": {"$ref": "#/$defs/confirmed_edge"}}, "cyclic_sccs": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}}}},
    "robot_cell": {"type": "object", "additionalProperties": false, "required": ["robot_id", "cell"], "properties": {"robot_id": {"type": "string"}, "cell": {"$ref": "#/$defs/cell"}}},
    "robot_path": {"type": "object", "additionalProperties": false, "required": ["robot_id", "cells"], "properties": {"robot_id": {"type": "string"}, "cells": {"type": "array", "items": {"$ref": "#/$defs/cell"}}}},
    "recovery_solver": {"type": "object", "additionalProperties": false, "required": ["solver", "seed", "max_timestep", "makespan", "source_commit"], "properties": {"solver": {"type": "string"}, "seed": {"type": "integer"}, "max_timestep": {"type": "integer", "minimum": 1}, "makespan": {"type": "integer", "minimum": 0}, "source_commit": {"type": "string"}}},
    "recovery": {"type": "object", "additionalProperties": false, "required": ["state", "failure_reason", "failure_detail", "failure_tick", "incident", "expected_plan_versions", "installed_plan_versions", "proposal_created_tick", "installation_tick", "completion_tick", "participants", "starts", "goals", "solver", "adg_compiled", "paths", "admission"], "properties": {"state": {"enum": ["not-attempted", "proposal-ready", "unsupported-or-failed", "install-failed", "installed", "executing", "admission-failed", "admission-stalled", "completed"]}, "failure_reason": {"type": ["string", "null"]}, "failure_detail": {"type": ["string", "null"]}, "failure_tick": {"type": ["integer", "null"]}, "incident": {"type": ["object", "null"]}, "expected_plan_versions": {"type": "array"}, "installed_plan_versions": {"type": "array"}, "proposal_created_tick": {"type": ["integer", "null"]}, "installation_tick": {"type": ["integer", "null"]}, "completion_tick": {"type": ["integer", "null"]}, "participants": {"type": "array", "items": {"type": "string"}}, "starts": {"type": "array", "items": {"$ref": "#/$defs/robot_cell"}}, "goals": {"type": "array", "items": {"$ref": "#/$defs/robot_cell"}}, "solver": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/recovery_solver"}]}, "adg_compiled": {"type": "boolean"}, "paths": {"type": "array", "items": {"$ref": "#/$defs/robot_path"}}, "admission": {"type": ["object", "null"]}}},
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "tick", "checkpoint", "robots", "tasks", "plans", "reservations", "preview", "deadlock", "confirmed_wait_for", "recovery", "events"],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "tick": {"type": "integer", "minimum": 0},
        "checkpoint": {"type": "string"},
        "robots": {"type": "array", "items": {"type": "object"}},
        "tasks": {"type": "array", "items": {"type": "object"}},
        "plans": {"type": "array", "items": {"type": "object"}},
        "reservations": {"type": "array", "items": {"type": "object"}},
        "preview": {"type": "object", "required": ["dependencies", "contentions", "cyclic_sccs"]},
        "deadlock": {"type": "object", "required": ["threshold", "candidates", "containment", "newly_stable"], "properties": {"candidates": {"type": "array", "items": {"$ref": "#/$defs/deadlock_candidate"}}, "containment": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/containment"}]}}},
        "confirmed_wait_for": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/confirmed_graph"}]},
        "recovery": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/recovery"}]},
        "events": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
