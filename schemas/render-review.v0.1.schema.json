{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MAPF Splice render review v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scenario_id", "routes", "views"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "render-review.v0.1"},
    "scenario_id": {"$ref": "#/$defs/id"},
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["robot_id", "cells"],
        "properties": {
          "robot_id": {"$ref": "#/$defs/id"},
          "cells": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/cell"}
          }
        }
      }
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "committed_horizon",
          "route_indices",
          "prospective_dependencies"
        ],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "committed_horizon": {"type": "integer", "minimum": 1},
          "route_indices": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {"type": "integer", "minimum": 0}
          },
          "prospective_dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["waiting_robot_id", "blocking_robot_id"],
              "properties": {
                "waiting_robot_id": {"$ref": "#/$defs/id"},
                "blocking_robot_id": {"$ref": "#/$defs/id"}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "col"],
      "properties": {
        "row": {"type": "integer", "minimum": 0},
        "col": {"type": "integer", "minimum": 0}
      }
    }
  }
}
