{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MAPF Splice scenario v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "seed",
    "map",
    "stations",
    "traffic",
    "execution",
    "deadlock_analysis",
    "fleet",
    "dispatcher",
    "task_stream"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "scenario.v0.1"},
    "id": {"$ref": "#/$defs/id"},
    "seed": {"type": "integer", "minimum": 0},
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "coordinate_system", "cell_size_m"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "coordinate_system": {"const": "row_col"},
        "cell_size_m": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "stations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "cell"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "kind": {"enum": ["handoff", "delivery"]},
          "cell": {"$ref": "#/$defs/cell"}
        }
      }
    },
    "traffic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["committed_horizon", "preview_horizon"],
      "properties": {
        "committed_horizon": {"$ref": "#/$defs/integer_range_with_default"},
        "preview_horizon": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {"mode": {"const": "match_committed"}}
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tick_duration_seconds",
        "base_move_duration_ticks",
        "delay_schedule"
      ],
      "properties": {
        "tick_duration_seconds": {"type": "number", "exclusiveMinimum": 0},
        "base_move_duration_ticks": {"type": "integer", "minimum": 1},
        "delay_schedule": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "seed", "probability", "extra_wait_ticks"],
          "properties": {
            "type": {"const": "seeded_extra_wait"},
            "seed": {"type": "integer", "minimum": 0},
            "probability": {"type": "number", "minimum": 0, "maximum": 1},
            "extra_wait_ticks": {"$ref": "#/$defs/integer_range"}
          }
        }
      }
    },
    "deadlock_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stable_scc_observation_threshold"],
      "properties": {
        "stable_scc_observation_threshold": {
          "type": "integer",
          "minimum": 1,
          "default": 2
        }
      }
    },
    "fleet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["robots"],
      "properties": {
        "robots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "start_station_id", "initial_payload"],
            "properties": {
              "id": {"$ref": "#/$defs/id"},
              "start_station_id": {"$ref": "#/$defs/id"},
              "initial_payload": {"const": "empty"}
            }
          }
        }
      }
    },
    "dispatcher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "task_order", "tie_breaker"],
      "properties": {
        "policy": {"const": "nearest_idle"},
        "task_order": {"const": "release_tick_then_task_id"},
        "tie_breaker": {"const": "robot_id"}
      }
    },
    "task_stream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "initial_tasks", "generator", "evaluation"],
      "properties": {
        "mode": {"const": "lifelong"},
        "initial_tasks": {
          "type": "array",
          "items": {"$ref": "#/$defs/task"}
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "seed",
            "release_interval_ticks",
            "max_pending_tasks",
            "pickup_station_ids",
            "delivery_station_ids",
            "prevent_immediate_pair_repeat"
          ],
          "properties": {
            "type": {"const": "seeded_station_pairs"},
            "seed": {"type": "integer", "minimum": 0},
            "release_interval_ticks": {
              "$ref": "#/$defs/positive_integer_range"
            },
            "max_pending_tasks": {"type": "integer", "minimum": 1},
            "pickup_station_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/id"}
            },
            "delivery_station_ids": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/id"}
            },
            "prevent_immediate_pair_repeat": {"type": "boolean"}
          }
        },
        "evaluation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stop_after_ticks"],
          "properties": {
            "stop_after_ticks": {"type": "integer", "minimum": 1}
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "col"],
      "properties": {
        "row": {"type": "integer", "minimum": 0},
        "col": {"type": "integer", "minimum": 0}
      }
    },
    "integer_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "integer", "minimum": 0},
        "maximum": {"type": "integer", "minimum": 0}
      }
    },
    "integer_range_with_default": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default", "minimum", "maximum"],
      "properties": {
        "default": {"type": "integer", "minimum": 1},
        "minimum": {"type": "integer", "minimum": 1},
        "maximum": {"type": "integer", "minimum": 1}
      }
    },
    "positive_integer_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum", "maximum"],
      "properties": {
        "minimum": {"type": "integer", "minimum": 1},
        "maximum": {"type": "integer", "minimum": 1}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "release_tick",
        "pickup_station_id",
        "delivery_station_id"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "release_tick": {"type": "integer", "minimum": 0},
        "pickup_station_id": {"$ref": "#/$defs/id"},
        "delivery_station_id": {"$ref": "#/$defs/id"}
      }
    }
  }
}
